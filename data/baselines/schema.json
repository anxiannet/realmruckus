{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "GEN-BASELINE-SCHEMA-001",
  "title": "Current Generic Test Baseline",
  "type": "object",
  "required": ["schema_version", "rules_version", "baseline_version", "model", "games_per_configuration", "seed", "total_games", "configurations"],
  "properties": {
    "schema_version": {"type": "string"},
    "rules_version": {"type": "string"},
    "baseline_version": {"type": "string"},
    "model": {"type": "string", "enum": ["human_like", "pressure"]},
    "games_per_configuration": {"type": "integer", "minimum": 1},
    "seed": {"type": "integer"},
    "total_games": {"type": "integer", "minimum": 1},
    "configurations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["deck", "deck_size"],
        "properties": {
          "deck": {"type": "string", "enum": ["core", "core_plus_expansion_1"]},
          "deck_size": {"type": "integer", "enum": [40, 50]},
          "players": {"type": "integer", "minimum": 2, "maximum": 4},
          "mode": {"type": "string", "enum": ["quick", "standard", "full"]},
          "area_count": {"type": "integer", "enum": [6, 9, 12]},
          "center_size": {"type": "integer", "enum": [2, 3]},
          "direct_wins": {"type": "integer", "minimum": 0},
          "settlements": {"type": "integer", "minimum": 0},
          "draws": {"type": "integer", "minimum": 0},
          "timeouts": {"type": "integer", "minimum": 0},
          "direct_win_rate": {"type": "number", "minimum": 0, "maximum": 1},
          "timeout_rate": {"type": "number", "minimum": 0, "maximum": 1},
          "average_turns": {"type": "number", "minimum": 0},
          "median_turns": {"type": "number", "minimum": 0},
          "p90_turns": {"type": "number", "minimum": 0},
          "deck_exhaustion_rate": {"type": "number", "minimum": 0, "maximum": 1},
          "average_successful_attacks": {"type": "number", "minimum": 0},
          "average_area_returns": {"type": "number", "minimum": 0}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
